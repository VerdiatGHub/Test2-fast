# ============================================================
#  Agent S2 + Orgo cloud, routed through 9Router (no paid OpenAI/Anthropic keys)
# ============================================================
# Copy this file to ".env" (setup.bat does that for you) and fill in the
# two values marked >>> EDIT THIS <<< below. See SETUP.md for the walkthrough.
# ------------------------------------------------------------

# ----- 9Router endpoint (local proxy - leave as-is) -----
OPENAI_BASE_URL="http://localhost:20128/v1"

# >>> EDIT THIS (1/2) <<<
# Paste the API key from the 9Router dashboard (http://localhost:20128 -> API Keys)
OPENAI_API_KEY="PASTE_9ROUTER_API_KEY_HERE"

# Anthropic SDK is not used (grounding is routed via the OpenAI path through 9Router),
# but the library imports it, so this dummy value just keeps it happy. Leave as-is.
ANTHROPIC_API_KEY="not-used-routed-via-9router"

# ===== CLOUD / REMOTE EXECUTION (Orgo) =====
USE_CLOUD_ENVIRONMENT=true
# >>> EDIT THIS (2/2) <<<
# Your Orgo key from https://orgo.ai
ORGO_API_KEY="PASTE_YOUR_ORGO_API_KEY_HERE"

# ===== Models (free, vision-capable Claude via Kiro through 9Router) =====
# Both roles go through 9Router's OpenAI-compatible API. Must be VISION-capable
# because Agent S2 sends a screenshot to the model on every step.
# kr/ = the FREE Kiro route. See live list at http://localhost:20128/v1/models
AGENT_MODEL="kr/claude-sonnet-4.5"
AGENT_MODEL_TYPE=openai
GROUNDING_MODEL="kr/claude-sonnet-4.5"
GROUNDING_MODEL_TYPE=openai

# ===== Optional =====
SEARCH_ENGINE=none
PERPLEXICA_URL=
EMBEDDING_TYPE=openai
MAX_STEPS=10
STEP_DELAY=0.5
